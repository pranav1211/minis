---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
    const posts = await getCollection('posts');
    return posts.map(post => ({
        params: { id: post.data.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});

const siteUrl = "https://minis.beyondmebtw.com";
const postUrl = `${siteUrl}/post/${post.data.id}/`;
const publishedTime = `${post.data.date}T${post.data.time}:00+05:30`;

// Get first 160 chars of content for description (strip markdown)
const rawText = post.body?.replace(/[#*_\[\]()>`~-]/g, '').replace(/\n+/g, ' ').trim() || '';
const description = rawText.substring(0, 160) + (rawText.length > 160 ? '...' : '');

// Related posts logic
const allPosts = await getCollection('posts');
const sortedOtherPosts = allPosts
    .filter(p => p.data.id !== post.data.id)
    .sort((a, b) => {
        const dateA = new Date(`${a.data.date}T${a.data.time || '00:00'}:00+05:30`);
        const dateB = new Date(`${b.data.date}T${b.data.time || '00:00'}:00+05:30`);
        return dateB.getTime() - dateA.getTime();
    });

const currentTags = post.data.tags || [];
let relatedPosts = [];
const usedIds = new Set();

// Try one post per tag (up to 3 tags)
for (const tag of currentTags.slice(0, 3)) {
    const tagged = sortedOtherPosts.filter(p =>
        !usedIds.has(p.data.id) &&
        (p.data.tags || []).includes(tag)
    );
    if (tagged.length > 0) {
        relatedPosts.push(tagged[0]);
        usedIds.add(tagged[0].data.id);
    }
}

// Fill remaining slots with latest posts
if (relatedPosts.length < 3) {
    const fillers = sortedOtherPosts.filter(p => !usedIds.has(p.data.id));
    for (const p of fillers) {
        if (relatedPosts.length >= 3) break;
        relatedPosts.push(p);
        usedIds.add(p.data.id);
    }
}

// Pre-compute related post display data in frontmatter (avoids block-body map in template)
const relatedPostsData = relatedPosts.map(p => ({
    id: p.data.id,
    title: p.data.title,
    date: new Date(p.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
    tags: (p.data.tags || []).slice(0, 3),
    excerpt: (p.body || '')
        .replace(/^---$/gm, '')
        .replace(/[#*_\[\]()>`~]/g, '')
        .replace(/\n+/g, ' ')
        .trim()
        .substring(0, 110),
}));

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "datePublished": publishedTime,
    "url": postUrl,
    "author": {
        "@type": "Person",
        "name": "Pranav Veeraghanta",
        "url": "https://beyondmebtw.com/about"
    },
    "publisher": {
        "@type": "Organization",
        "name": "Beyond Me Btw",
        "url": "https://beyondmebtw.com"
    },
    "keywords": post.data.tags.join(', ')
};

const twitterShareUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(post.data.title)}`;
const blueskyShareUrl = `https://bsky.app/intent/compose?text=${encodeURIComponent(post.data.title + ' ' + postUrl)}`;
---

<BaseLayout
    title={`${post.data.title} | Minis`}
    description={description}
    ogTitle={post.data.title}
    ogType="article"
    publishedTime={publishedTime}
    canonicalUrl={postUrl}
>
    <Fragment slot="head">
        {post.data.tags.map(tag => (
            <meta property="article:tag" content={tag} />
        ))}
        <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" />
    </Fragment>

    <div class="post-page-layout">
        <Header />
        <main class="post-page">
            <a href="/" class="back-link-top"><i class="fas fa-arrow-left"></i> all minis</a>

            <article>
                <header class="post-header">
                    <h1>{post.data.title}</h1>
                    <div class="post-date">
                        <time datetime={post.data.date}>{formattedDate}</time>
                        <span class="post-time-sep">·</span>
                        <span class="post-time">{post.data.time} IST</span>
                    </div>
                    <div class="post-tags-row">
                        <div class="post-tags">
                            {post.data.tags.map(tag => (
                                <a href={`/?tag=${tag}`} class="tag">{tag}</a>
                            ))}
                        </div>
                        <div class="post-share-inline">
                            <button class="share-btn share-copy" id="shareCopyBtn">
                                <i class="fas fa-link"></i> Copy Link
                            </button>
                            <a href={twitterShareUrl} class="share-btn share-twitter" target="_blank" rel="noopener noreferrer">
                                <i class="fa-brands fa-x-twitter"></i> Share
                            </a>
                            <a href={blueskyShareUrl} class="share-btn share-bluesky" target="_blank" rel="noopener noreferrer">
                                <i class="fa-brands fa-bluesky"></i> Share
                            </a>
                        </div>
                    </div>
                </header>

                <div class="post-content">
                    <Content />
                </div>
            </article>

            {relatedPostsData.length > 0 && (
                <section class="related-posts">
                    <div class="related-posts-header">
                        <h2>more minis</h2>
                    </div>
                    <div class="related-posts-grid">
                        {relatedPostsData.map(p => (
                            <a href={`/post/${p.id}`} class="related-post-card">
                                <div class="related-post-tags">
                                    {p.tags.map(t => (
                                        <span class="related-tag">{t}</span>
                                    ))}
                                </div>
                                <div class="related-post-title">{p.title}</div>
                                <div class="related-post-date">{p.date}</div>
                                {p.excerpt && <div class="related-post-excerpt">{p.excerpt}…</div>}
                            </a>
                        ))}
                    </div>
                </section>
            )}
        </main>
        <Footer />
    </div>

    <button class="scroll-to-top" id="scrollToTop" aria-label="Scroll to top">
        <i class="fas fa-arrow-up"></i>
    </button>
</BaseLayout>

<script>
    const scrollToTopBtn = document.getElementById('scrollToTop');
    const shareCopyBtn = document.getElementById('shareCopyBtn');

    if (scrollToTopBtn) {
        window.addEventListener('scroll', () => {
            if (window.pageYOffset > 300) {
                scrollToTopBtn.classList.add('visible');
            } else {
                scrollToTopBtn.classList.remove('visible');
            }
        });
        scrollToTopBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }

    if (shareCopyBtn) {
        shareCopyBtn.addEventListener('click', async () => {
            try {
                const url = window.location.href.endsWith('/') ? window.location.href : window.location.href + '/';
                await navigator.clipboard.writeText(url);
                shareCopyBtn.classList.add('copied');
                setTimeout(() => shareCopyBtn.classList.remove('copied'), 2000);
            } catch (e) {}
        });
    }
</script>
